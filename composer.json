{
    "name": "th/module-r2",
    "description": "Cloudflare R2 remote media storage integration for Magento 2 and Adobe Commerce.",
    "keywords": [
        "magento2",
        "adobe-commerce",
        "cloudflare",
        "r2",
        "media",
        "remote-storage"
    ],
    "homepage": "https://github.com/tuanhaviet22/magento2-module-r2",
    "type": "magento2-module",
    "require": {
        "aws/aws-sdk-php": "^3.0",
        "magento/framework": "103.0.*",
        "magento/module-aws-s3": "100.4.*",
        "magento/module-config": "101.2.*",
        "magento/module-remote-storage": "100.4.*",
        "php": "~8.1.0||~8.2.0||~8.3.0"
    },
    "license": [
        "MIT"
    ],
    "autoload": {
        "files": [
            "src/registration.php"
        ],
        "psr-4": {
            "TH\\R2\\": "src"
        }
    },
    "repositories": {
        "magento": {
            "type": "composer",
            "url": "https://repo.magento.com/"
        }
    },
    "config": {
        "allow-plugins": {
            "magento/composer-dependency-version-audit-plugin": true,
            "magento/magento-composer-installer": true,
            "php-http/discovery": true
        },
        "sort-packages": true
    }
}
